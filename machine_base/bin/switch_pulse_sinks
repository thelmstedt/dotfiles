#!/usr/bin/env bash

HEADPHONES="alsa_output.usb-JDS_Labs_JDS_Labs_Atom_DAC_2-00.iec958-stereo"
SPEAKERS="alsa_output.usb-SMSL_AUDIO_SMSL_AD18_AMP-00.iec958-stereo"

CURRENT=$(pactl get-default-sink)

if [ "$CURRENT" = "$HEADPHONES" ]; then
    TARGET="$SPEAKERS"
else
    TARGET="$HEADPHONES"
fi

pactl set-default-sink "$TARGET"

# move all active streams
pactl list short sink-inputs | awk '{print $1}' | while read -r input; do
    pactl move-sink-input "$input" "$TARGET"
done

echo "switched to: $TARGET"